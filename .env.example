# Real key goes in .env (gitignored); never commit a live key.
OPENAI_API_KEY=

# Firebase (Google login + real-time progress mirror, D45): NO secret is required.
# The public web config lives in ts/lib/manifold/firebase.config.ts (committed by
# design — a Firebase web apiKey is not a secret; security is the Firestore rules +
# authorized domains). Desktop sign-in uses a system-browser loopback with that
# public config, so nothing Firebase-related belongs in .env.
